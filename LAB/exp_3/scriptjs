const heading = document.getElementById('heading');
const paragraph = document.getElementById('paragraph');
const input = document.getElementById('textInput');
const card = document.getElementById('mainCard');

let fontSize = 16;

document.getElementById('btnHeading').addEventListener('click', () => {
    if(input.value !== "") {
        heading.innerText = input.value;
    }
});

document.getElementById('btnBg').addEventListener('click', () => {
    const randomColor = `hsl(${Math.random() * 360}, 70%, 90%)`;
    card.style.backgroundColor = randomColor;
});

document.getElementById('btnFont').addEventListener('click', () => {
    fontSize += 2;
    paragraph.style.fontSize = fontSize + "px";
});

document.getElementById('btnToggle').addEventListener('click', () => {
    if (paragraph.style.display === "none") {
        paragraph.style.display = "block";
    } else {
        paragraph.style.display = "none";
    }
});

document.getElementById('btnReset').addEventListener('click', () => {
    heading.innerText = "Welcome to JavaScript Lab";
    card.style.backgroundColor = "white";
    fontSize = 16;
    paragraph.style.fontSize = "16px";
    paragraph.style.display = "block";
    input.value = "";
});